---
import Navbar from '../components/ui/Navbar.astro';
import AccessibilityMenu from '../components/ui/AccessibilityMenu.astro';
import '../styles/global.css';

interface Props {
  title: string;
  lang?: string;
}

const { title, lang = 'es' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content="Porfolio de Daniel Carrasco García – Desarrollador Frontend y especialista en tecnología aeroespacial." />
    <meta name="author" content="Daniel Carrasco García" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- SVG Filters daltonismo -->
    <svg aria-hidden="true" focusable="false" style="position:absolute;width:0;height:0;overflow:hidden">
      <defs>
        <filter id="deuteranopia">
          <feColorMatrix type="matrix"
            values="0.367 0.861 -0.228 0 0
                    0.280 0.673  0.047 0 0
                   -0.012 0.043 0.969 0 0
                    0     0     0     1 0"/>
        </filter>
        <filter id="protanopia">
          <feColorMatrix type="matrix"
            values="0.152 1.053 -0.205 0 0
                    0.115 0.786  0.099 0 0
                   -0.004 -0.048 1.052 0 0
                    0     0      0     1 0"/>
        </filter>
        <filter id="tritanopia">
          <feColorMatrix type="matrix"
            values="1.256 -0.077 -0.179 0 0
                   -0.078  0.931  0.148 0 0
                    0.005  0.692  0.303 0 0
                    0      0      0     1 0"/>
        </filter>
      </defs>
    </svg>

    <!-- Script de preferencias (sin FOUC) -->
    <script is:inline>
      (function () {
        var contrast = localStorage.getItem('a11y-contrast') === 'true';
        var fontSize  = localStorage.getItem('a11y-font') || 'normal';
        var sizes = { small: '14px', normal: '16px', large: '19px' };
        if (contrast) document.documentElement.setAttribute('data-theme', 'high-contrast');
        document.documentElement.style.fontSize = sizes[fontSize] || '16px';
      })();
    </script>
  </head>

  <body class="bg-[var(--color-bg-primary)] text-[var(--color-text-primary)] antialiased font-sans">

    <Navbar lang={lang} currentPath={currentPath} />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <AccessibilityMenu />

  </body>
</html>
