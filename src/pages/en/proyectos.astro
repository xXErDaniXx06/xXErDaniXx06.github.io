const getProjectConfig = (id: string) => {
  return idMap[id] || idMap.ksat;
};
---

<Layout title={t.meta_title} lang={lang}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 pb-24">

    <!-- Header -->
    <header class="mb-16 text-center md:text-left">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 mb-4 rounded-full
                   border border-sky-400/30 bg-sky-400/10 text-sky-400
                   text-xs font-semibold tracking-widest uppercase">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
        {t.tag}
      </span>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-white mb-3">
        {t.title}
        <span class="bg-gradient-to-r from-sky-400 to-indigo-400 bg-clip-text text-transparent">{t.title_highlight}</span>
      </h1>
      <p class="text-slate-400 max-w-2xl text-lg leading-relaxed">
        {t.subtitle}
      </p>
    </header>

    <!-- Linear project list -->
    <div class="max-w-6xl mx-auto p-4 flex flex-col gap-20">
      {t.list.map((project: any, index: number) => {
        const config = getProjectConfig(project.id);
        const isOdd = index % 2 === 1;

        return (
          <article
            id={`project-${project.id}`}
            class={`flex flex-col md:flex-row gap-8 items-center bg-transparent border-none ${isOdd ? 'md:flex-row-reverse' : ''}`}
            aria-label={`Project ${project.title}`}
          >
            <!-- Text Block (50%) -->
            <div class="w-full md:w-1/2 flex flex-col gap-4">
              
              <!-- Header -->
              <div class="flex flex-col gap-2">
                <div class="flex items-center gap-3">
                  <div class={`w-12 h-12 rounded-xl border flex items-center justify-center shrink-0 ${config.accentBg} ${config.accentText} shadow-md`}>
                    <Fragment set:html={config.iconSvg} />
                  </div>
                  <div>
                    <h2 class="text-2xl font-bold text-white tracking-tight">{project.title}</h2>
                    <p class="text-sm text-slate-500">{project.org}</p>
                  </div>
                </div>
                
                <div class="flex items-center gap-3 mt-1">
                  {project.active ? (
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-semibold
                                 bg-emerald-500/10 text-emerald-300 border border-emerald-500/20">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse" aria-hidden="true"></span>
                      {t.status_active}
                    </span>
                  ) : (
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold
                                 bg-slate-500/10 text-slate-400 border border-slate-500/20">
                      {t.status_completed}
                    </span>
                  )}
                  <time class="text-xs text-slate-400 font-medium">{project.time}</time>
                </div>
              </div>

              <!-- Description -->
              <p class="text-slate-300 text-base leading-relaxed">
                <Fragment set:html={project.description} />
              </p>

              <!-- Milestones -->
              <ul class="space-y-2.5 my-2" aria-label={`Milestones of project ${project.title}`}>
                {project.milestones.map((m: any) => (
                  <li class="flex items-start gap-2.5 text-sm text-slate-400">
                    <svg class={`w-4 h-4 shrink-0 mt-0.5 ${config.accentText}`} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                    </svg>
                    <span>{m}</span>
                  </li>
                ))}
              </ul>

              <!-- Tags / Badges -->
              <div class="flex flex-wrap gap-2 mt-2">
                {project.tags.map((tag: any) => {
                  const tagClass = config.tagClasses[tag] || 'bg-slate-500/10 text-slate-300 border-slate-500/25';
                  return (
                    <span class={`px-3 py-1 rounded-lg text-xs font-semibold border ${tagClass}`}>
                      {tag}
                    </span>
                  );
                })}
              </div>

            </div>

            <!-- Multimedia Block (50%) -->
            <div class="w-full md:w-1/2">
              {config.media ? (
                <div class="rounded-2xl overflow-hidden shadow-2xl border border-slate-700 bg-black/20 relative group/media">
                  {config.media.type === 'video' ? (
                    <video
                      src={config.media.src}
                      autoplay
                      loop
                      muted
                      playsinline
                      controls
                      class="w-full aspect-video object-cover"
                    />
                  ) : (
                    <img
                      src={config.media.src}
                      alt={project.title}
                      class="w-full aspect-video object-cover group-hover/media:scale-[1.02] transition-transform duration-500"
                    />
                  )}
                </div>
              ) : (
                /* Fallback visual premium */
                <div class="rounded-2xl w-full aspect-video flex items-center justify-center bg-gradient-to-br from-[#0d1527] via-[#111c36] to-[#0a0f1e] shadow-2xl border border-slate-700 relative overflow-hidden group/fallback">
                  <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(56,189,248,0.06),transparent_60%)]" aria-hidden="true"></div>
                  <div class="w-16 h-16 rounded-2xl flex items-center justify-center bg-slate-900/50 border border-slate-800 text-sky-400 group-hover/fallback:scale-110 transition-transform duration-300">
                    <Fragment set:html={config.iconSvg} />
                  </div>
                </div>
              )}
            </div>

          </article>
        );
      })}
    </div>
  </section>
</Layout>
