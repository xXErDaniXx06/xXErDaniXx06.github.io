    },
    media: { type: 'image', src: '/images/sensordeco2.png' }
  },
  smartdoor: {
    borderHover: 'hover:border-blue-500/40',
    accentText: 'text-blue-400',
    accentBg: 'bg-blue-500/10 border-blue-500/20',
