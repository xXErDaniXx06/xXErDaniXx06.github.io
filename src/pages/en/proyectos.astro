  oracle: {
    borderHover: 'hover:border-amber-500/40',
    accentText: 'text-amber-400',
    accentBg: 'bg-amber-500/10 border-amber-500/20',
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm1 14.93V15h-2v1.93A8 8 0 0 1 4.07 11H6V9H4.07A8 8 0 0 1 11 4.07V6h2V4.07A8 8 0 0 1 19.93 11H18v2h1.93A8 8 0 0 1 13 16.93z"/>
            </svg>`,
    tagClasses: {
      Python: 'bg-amber-500/10 text-amber-300 border-amber-500/25',
      'AI / ML': 'bg-yellow-500/10 text-yellow-300 border-yellow-500/25',
      Firebase: 'bg-orange-500/10 text-orange-300 border-orange-500/25',
      'Full-Stack': 'bg-sky-500/10 text-sky-300 border-sky-500/25'
    },
    media: { type: 'image', src: '/images/Oracle_Image.jpg' }
  },
  futuro: {
    borderHover: 'hover:border-sky-500/40',
    accentText: 'text-sky-400',
    accentBg: 'bg-sky-500/10 border-sky-500/20',
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm1 14.93V15h-2v1.93A8 8 0 0 1 4.07 11H6V9H4.07A8 8 0 0 1 11 4.07V6h2V4.07A8 8 0 0 1 19.93 11H18v2h1.93A8 8 0 0 1 13 16.93z"/></svg>`,
    tagClasses: {
      'IA / ML': 'bg-sky-500/10 text-sky-300 border-sky-500/25',
      'Trading': 'bg-blue-500/10 text-blue-300 border-blue-500/25',
      'Quantum': 'bg-indigo-500/10 text-indigo-300 border-indigo-500/25'
    },
    media: { type: 'image', src: '/images/FuturosProyectos_Image.jpg' }
