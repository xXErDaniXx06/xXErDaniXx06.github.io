---
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../utils/i18n.js';

const lang = 'en';
const t = getTranslations(lang).index;
---

<Layout title={t.meta_title} lang={lang}>

  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden py-16 md:py-24">
    <!-- Premium decorative background glows -->
    <div class="absolute -top-40 right-0 w-[500px] h-[500px] rounded-full
                bg-sky-500/10 blur-3xl pointer-events-none animate-pulse" style="animation-duration: 8s;" aria-hidden="true"></div>
    <div class="absolute -bottom-40 left-0 w-[500px] h-[500px] rounded-full
                bg-indigo-500/10 blur-3xl pointer-events-none animate-pulse" style="animation-duration: 12s;" aria-hidden="true"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 w-full">
      <div class="flex flex-col-reverse md:flex-row items-center justify-between gap-12 md:gap-16">
        
        <!-- Left Column: Text & Buttons (60% width) -->
        <div class="w-full md:w-[60%] flex flex-col items-start text-left">
          
          <!-- Premium badge with micro-animation -->
          <span class="inline-flex items-center gap-2 px-4 py-1.5 mb-6
                       rounded-full border border-sky-400/20 bg-sky-400/5
                       text-sky-400 text-xs font-semibold tracking-wider uppercase backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-sky-400"></span>
            </span>
            {t.hero.badge}
          </span>

          <!-- Main Title -->
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] mb-4 text-white">
            {t.hero.greeting} <br class="sm:hidden" />
            <span class="bg-gradient-to-r from-sky-400 via-blue-400 to-indigo-400
                         bg-clip-text text-transparent drop-shadow-sm font-black">
              Daniel Carrasco García
            </span>
          </h1>

          <!-- Subtitle -->
          <p class="text-lg sm:text-xl lg:text-2xl font-bold text-slate-200 mb-6 tracking-wide leading-relaxed">
            Computer Engineering Student <span class="text-sky-400">|</span> Software, Hardware & Aerospace Tech
          </p>

          <!-- Condensed Description (max 4 lines) -->
          <p class="text-slate-400 leading-relaxed text-base lg:text-lg mb-10 max-w-2xl">
            I'm Daniel Carrasco García, a Computer Engineering student at the University of Málaga, with a deep passion for technology, software development, and the aerospace sector. I enjoy building practical and innovative solutions by combining hardware and software, from PCB design and RF links to full-stack applications and AI models.
          </p>

          <!-- Action Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            <a
              href={`/${lang}/proyectos`}
              class="group inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl
                     bg-sky-500 hover:bg-sky-400 text-white font-bold text-base
                     shadow-lg shadow-sky-500/25 hover:shadow-sky-400/35
                     transition-all duration-300 hover:-translate-y-1 active:translate-y-0 text-center"
            >
              {t.hero.cta_projects}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a
              href="/docs/CV_Daniel.pdf"
              download
              class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl
                     border border-white/10 bg-white/5 hover:bg-white/10
                     text-slate-200 hover:text-white font-bold text-base backdrop-blur-sm
                     transition-all duration-300 hover:-translate-y-1 active:translate-y-0 text-center"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 16l-5-5 1.41-1.41L11 13.17V4h2v9.17l2.59-2.58L17 11l-5 5zm-7 3h14v-2H5v2z"/>
              </svg>
              {t.hero.cta_cv}
            </a>
          </div>
        </div>

        <!-- Right Column: Profile Image (40% width) -->
        <div class="w-full md:w-[40%] flex justify-center items-center">
          <div class="relative w-64 aspect-[4/5] sm:w-80 md:w-[340px] group">
            <!-- Interactive radial glow behind the photo -->
            <div class="absolute inset-0 rounded-[60%_40%_30%_70%_/_60%_30%_70%_40%] bg-gradient-to-tr from-sky-500 to-indigo-500 opacity-25 blur-2xl group-hover:opacity-40 transition-all duration-700 ease-in-out group-hover:rounded-[40%_60%_70%_30%_/_40%_50%_50%_60%]"></div>
            
            <!-- Photo with organic blob masking and hover morphing -->
            <div class="w-full h-full rounded-[60%_40%_30%_70%_/_60%_30%_70%_40%] overflow-hidden border border-white/10 shadow-2xl transition-all duration-700 ease-in-out group-hover:scale-[1.02] group-hover:border-sky-400/40 group-hover:rounded-[40%_60%_70%_30%_/_40%_50%_50%_60%] bg-slate-950 relative">
              <!-- Base photo (normal): profile2.jpeg -->
              <img
                src="/images/profile2.jpeg"
                alt="Daniel Carrasco García"
                class="absolute inset-0 w-full h-full object-cover object-top filter brightness-95 contrast-105 transition-all duration-700 group-hover:opacity-0 group-hover:scale-105"
              />
              <!-- Hover photo: profile.jpg -->
              <img
                src="/images/profile.jpg"
                alt="Daniel Carrasco García"
                class="absolute inset-0 w-full h-full object-cover object-top filter brightness-95 contrast-105 transition-all duration-700 opacity-0 scale-95 group-hover:opacity-100 group-hover:scale-100"
              />
            </div>
            
            <!-- Decorative floating badge -->
            <div class="absolute -bottom-3 -left-3 w-14 h-14 rounded-2xl bg-[#0a0f1e]/90 border border-white/10 flex items-center justify-center shadow-2xl transition-transform duration-500 group-hover:rotate-12 backdrop-blur-md">
              <span class="text-sky-400 font-bold text-xl" aria-hidden="true">&lt;/&gt;</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
